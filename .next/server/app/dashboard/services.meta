{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/services/layout,_N_T_/dashboard/services/page,_N_T_/dashboard/services"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/services/__PAGE__",
    "/dashboard/services",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}