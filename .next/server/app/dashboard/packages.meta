{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/packages/layout,_N_T_/dashboard/packages/page,_N_T_/dashboard/packages"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/packages/__PAGE__",
    "/dashboard/packages",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}