# ===========================================
# ICUBE Media Studio – Environment variables
# Copy to .env or .env.local and fill with your values.
# Never commit .env or .env.local (they are in .gitignore).
# ===========================================

# ---- Server-only (do NOT expose in client) ----
# GEMINI_API_KEY: Used by optional server features (e.g. AI). Not needed for Firebase-only setup.
GEMINI_API_KEY="your-gemini-api-key"

# APP_URL: Base URL of the deployed app (e.g. https://your-domain.vercel.app)
APP_URL="https://your-domain.com"

# ---- Firebase (client; Next.js) ----
# Required for the app. Get these from Firebase Console → Project settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789012"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789012:web:abcdef123456"

# ---- Cloudinary (dashboard uploads: images & videos to website) ----
# From Cloudinary Console → Product Environment Credentials
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Optional: use CLOUDINARY_URL instead: cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ---- Upload API (recommended for production) ----
# Set UPLOAD_API_KEY (server) and NEXT_PUBLIC_UPLOAD_API_KEY (client) to the same secret.
# Requests must send header x-upload-key with this value. If unset, upload is allowed (dev only).
# UPLOAD_API_KEY="your-long-random-secret"
# NEXT_PUBLIC_UPLOAD_API_KEY="your-long-random-secret"

# ---- Contact form & booking emails (Resend) ----
# Get API key at https://resend.com.
RESEND_API_KEY="re_xxxxxxxxxxxx"
# For inbox delivery (not spam): verify your domain at https://resend.com/domains, then set:
# CONTACT_FROM_EMAIL="ICUBE Media Studio <noreply@icubeproduction.com>"
# Optional: override recipient for contact form (default: info@icubeproduction.com)
# CONTACT_TO_EMAIL="info@icubeproduction.com"
